@article{li_study_2021,
	title = {Study on the {Variable}-{Temperature} {Drying} {Process} of {Corn} {Drying} in an {Industrial} {Corn}-{Drying} {System} {Equipped} with a {Self}-{Adaptive} {Control} {Heat} {Exchanger}},
