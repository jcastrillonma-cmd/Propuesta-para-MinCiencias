	url = {http://ejfa.me/index.php/journal/article/view/2040},
	doi = {10.9755/ejfa.2019.v31.i12.2040},
	abstract = {The main objective of this study was to simulate the economic feasibility of low-temperature grain drying systems considering Brazilian conditions and using three drying capacities, seven grain types and two furnace fuels. For this, 42 scenarios were simulated and compared among themselves by using an economic analysis based on the cash flow model with project lifetime of 20 years. The indices net present value, payback period, benefit-cost ratio and internal rate of return were applied during the analyses. Simulations showed that drying of coffee and beans in large systems presented higher economic feasibility, regardless of the furnace fuel used. All simulated scenarios were cost-effective provided that at least two drying cycles are performed per year. Labor costs, social taxes, grain type and drying capacity most affected the profitability of this kind of investment, while the furnace fuel less influenced the evaluated economic indices.},
	urldate = {2026-03-19},
	journal = {Emirates Journal of Food and Agriculture},
	author = {Santana, Pricila Araújo and Carvalho Lopes, Daniela De and Steidle Neto, Antonio José},
	month = jan,
	year = {2020},
	keywords = {coffee\_drying\_stage, energy\_efficiency, mechanical\_drying},
	pages = {930},
}

@article{munoz-neira_comparative_2019,
	title = {Comparative analysis of drying coffee beans using microwave and conventional oven},
	copyright = {https://creativecommons.org/licenses/by-nc-sa/4.0},
	issn = {2422-2844, 0120-6230},
	url = {https://revistas.udea.edu.co/index.php/ingenieria/article/view/336758},
	doi = {10.17533/udea.redin.20191151},
	abstract = {This article reports a comparative study of experimental results obtained during the drying of Castilla-variety coffee beans from Santander, Colombia. They were performed by two means: thermal and electromagnetic radiation. Twenty experiments were carried out, ten tests in a microwave cavity at 2,450 MHz-1,080W, and ten tests using a conventional electric oven with temperature controlled at 50±2oC. Experiments were made using samples of coffee beans with parchment, without parchment, and of the only-parchment. For each sample, dimensionless moisture ratio and diffusion coefficients were determined, according to the second law of Fick. We found that the diffusion coefficient of the samples dried in a microwave cavity was twenty-two times higher than the diffusion coefficient of samples dried with thermal radiation. Likewise, it was observed that samples in conventional oven showed a uniform temperature, in contrast with those heated by microwave radiation. Such results are useful for designing hybrid systems for drying coffee beans.},
	number = {95},
	urldate = {2026-03-19},
	journal = {Revista Facultad de Ingeniería Universidad de Antioquia},
	author = {Muñoz-Neira, Milton Javier and Roa-Ardila, Manuel Fernando and Correa-Celi, Carlos Rodrigo},
	month = dec,
	year = {2019},
	keywords = {coffee\_drying\_stage, drying\_kinetics, mechanical\_drying},
	pages = {100--108},
}

@article{munoz_endocarp_2019,
	title = {Endocarp analysis of a traditional variety of colombian coffee},
	volume = {14},
	issn = {1984-3909, 1809-6875},
	url = {http://www.coffeescience.ufla.br/index.php/Coffeescience/article/view/1572},
	doi = {10.25186/cs.v14i2.1572},
	abstract = {{\textless}p{\textgreater} This article presents the main results of thermal analytical and drying tests applied to the endocarp of coffee bean samples, in order to analyze their influence on the coffee dehydration process. An infrared analysis, as well as TGA, DTGA and DSC tests, were applied to the parchment of a sample of Castilla variety coffee beans and later compared with similar tests performed on coffee beans of the same variety, upon parchment removal. For analytical tests, the main thermogravimetric transitions are reported up to a temperature of 1000 °C. From thermograms, four temperature range were identified for parchment, with their respective mass loss: 33-33.7°C, 9.48\%; 33.7-251.2°C, 16.23\%; 251.2-358°C, 47.48\%; and 358-800°C, 15.52\%. The greatest mass loss was due to cellulose and hemicellulose degradation. The study was complemented by drying experiments on samples of beans with and without parchment. The diffusion coefficients were found using Fick’s second law and metaheuristic optimization methods (global optimization). On average, the diffusion coefficient of grains without endocarp is 46\% greater than that of beans dried with the parchment. Coffee beans with parchment took, on average, 50\% more time to reaching moisture levels of 12\% (on dry basis). The results are considered important for the projection and design of new coffee drying systems and their automatic control. {\textless}/p{\textgreater}},
	number = {2},
	urldate = {2026-03-19},
	journal = {Coffee Science},
	author = {Muñoz, Milton and Roa, Manuel and Correa, Rodrigo},
	month = jun,
	year = {2019},
	keywords = {coffee\_drying\_stage, coffee\_quality},
	pages = {206},
}

@article{hasan_comparative_2024,
	title = {Comparative {Life} {Cycle} {Assessment} ({LCA}) in the {Agri}-{Food} {Industry}, {Focusing} on {Organic} and {Conventional} {Coffee}},
	volume = {16},
	issn = {2071-1050},
	url = {https://www.mdpi.com/2071-1050/16/24/10819},
	doi = {10.3390/su162410819},
	abstract = {This study evaluates the environmental burden of organic and conventional coffee systems with a functional unit (FU) of 1 kg for market-ready, dried coffee. The ISO 14040 and ISO 14044 framework and guidelines are applied to organic and conventional coffee systems, using a cradle-to-grave approach and the methodology of ReCiPe Endpoint 2008, cumulative energy demand (CED), and the Intergovernmental Panel for Climate Change (IPCC). Superior sustainability was achieved for organic coffee compared to the performance of conventional coffee, with values of 218.50 mPt (conventional) and 146.10 mPt (organic), and a global warming potential (GWP) of 2.12 kg CO2 eq FU−1 (organic) and 1.44 kg CO2 eq FU−1 (conventional). CED fossil-based consumption totalled 25 MJ and 35 MJ for organic and conventional coffee systems, respectively. Conventional and organic coffee system hotspots stemmed from the planting (chemical fertilizer), drying, and packaging processes. This study emphasizes the environmental benefits of organic practices and their relatively lower impact than conventional methods. Within a growing sector, best management practices in the form of actionable insights from a life cycle assessment must be sought to ensure environmental sustainability in parallel with the UN’s goals.},
	language = {en},
	number = {24},
	urldate = {2026-03-19},
	journal = {Sustainability},
	author = {Hasan, Yusra and Roy, Poritosh and Abbassi, Bassim},
	month = dec,
	year = {2024},
	keywords = {coffee\_processing},
	pages = {10819},
}

