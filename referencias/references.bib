@article{gunawan_enhancing_2021,
	title = {Enhancing the performance of conventional coffee beans drying with low-temperature geothermal energy by applying {HPHE}: {An} experimental study},
	volume = {6},
	copyright = {http://creativecommons.org/licenses/by/4.0},
	issn = {2391-9531},
	shorttitle = {Enhancing the performance of conventional coffee beans drying with low-temperature geothermal energy by applying {HPHE}},
	url = {https://www.degruyterbrill.com/document/doi/10.1515/opag-2021-0053/html},
	doi = {10.1515/opag-2021-0053},
	abstract = {Abstract
            The unpredictable weather in Indonesia results in a less effective conventional coffee beans drying process, which usually uses solar energy as a heat source. This experiment aimed to examine the performance of the coffee beans drying using low-temperature geothermal energy (LTGE) with solar energy as the energy source. Heat pipe heat exchanger, which consists of 42 straight heat pipes with staggered configuration, was used to extract the LTGE. The heat pipes have 700 mm length, 10 mm outside diameter with a filling ratio of 50\%, and added by 181 pieces of aluminum with a dimension size of 76  mm × 345  mm × 0.105 mm as fins. LTGE was simulated by using water that is heated by three heaters and flowed by a pump. Meanwhile, to simulate the drying process with conventional methods, a system of solar air collectors made of polyurethane sheets with a thickness of 20 mm and dimensions of length × width × height = 160 cm × 76 cm × 10 cm, respectively, was used in this study. Zinc galvalume sheet with 0.3 mm thickness was installed and coated by the black doff color throughout the inner of the container wall. The result showed that the drying process with LTGE and solar energy is faster than with solar energy or geothermal energy only. The drying coffee beans using the hybrid system can speed up the drying coffee beans time by about 23\% faster than the solar energy only.},
	language = {en},
	number = {1},
	urldate = {2026-03-19},
	journal = {Open Agriculture},
	author = {Gunawan, Yohanes and Margono, Kukuh Tri and Rizky, Romy and Putra, Nandy and Faqih, Rizal Al and Hakim, Imansyah Ibnu and Setiadanu, Guntur Tri and Suntoro, Dedi and Kasbi, Slamet and Nafis, Subhan},
	month = dec,
	year = {2021},
	keywords = {coffee\_drying\_stage, mechanical\_drying},
	pages = {807--818},
}

@article{guerra_garcia_bioclimatic_2022,
	title = {Bioclimatic performance of wet coffee processing facilities: conditions for workers and coffee},
	volume = {75},
	copyright = {https://creativecommons.org/licenses/by-nc-sa/4.0},
	issn = {2248-7026, 0304-2847},
	shorttitle = {Bioclimatic performance of wet coffee processing facilities},
	url = {https://revistas.unal.edu.co/index.php/refame/article/view/96247},
	doi = {10.15446/rfnam.v75n1.96247},
	abstract = {This study aimed to evaluate the bioclimatic performance of three wet coffee processing facilities in Colombia, focused on the conditions for workers and coffee parchment, through computer simulation. In addition to temperature and relative humidity, the Wet-Bulb Globe Temperature index (WBGT) was simulated during the highest coffee production month. The proposed simulation model was able to predict hygrothermal behavior within the three coffee processing facilities. Case 3 presented the warmest environment, and case 2 the most humid environment concerning the appropriate conditions for the coffee and the worker. The WBGT index limit was exceeded in case 3. Since this type of facility emits large amounts of heat and steam, constructive modifications are suggested to improve the environmental conditions of workers and coffee. Mainly, the physical separation of the heat exchangers is recommended, which ideally should be outside the post-harvest facility. The steam produced in the drying process should be quickly evacuated with ventilation strategies. Additionally, the use of strategies that reduce the energy gain from solar radiation is suggested.},
	number = {1},
	urldate = {2026-03-19},
	journal = {Revista Facultad Nacional de Agronomía Medellín},
	author = {Guerra García, Lina Marcela and Osorio Hernandez, Robinson and Osorio Saráz, Jairo Alexander and Correna Carlo, Joyce and Alves Damasceno, Flavio},
	month = jan,
	year = {2022},
	keywords = {coffee\_processing},
}

@article{parra-coronado_preliminary_2020,
	title = {Preliminary study of drying of natural coffee by cyclical pressure changes},
	volume = {87},
	copyright = {https://creativecommons.org/licenses/by-nc-nd/4.0},
	issn = {2346-2183, 0012-7353},
	url = {https://revistas.unal.edu.co/index.php/dyna/article/view/83414},
	doi = {10.15446/dyna.v87n214.83414},
	abstract = {A “special coffee” is obtained with an adequate drying process, which allows the preservation of volatile substances responsible for excellent cup quality. The aim was to carry out preliminary studies of drying of natural coffee by implementing a Cyclic Pressure Changes (CPCD) dryer, comparing it with solar drying and with a mechanical drying system by forced convection of low-temperature air. The drying times and rates of the systems used were compared, as well as the respective valuation of the cup quality. Drying times were 767 h for solar drying system, without reaching the desired moisture content; 153.5 h for mechanical drying system and 449 h for the CPCD system. However, the global cup tests showed a better quality of the grain obtained with the CPCD system (87 points), than the one obtained with the mechanical drying at 35°C (84 points).},
	number = {214},
	urldate = {2026-03-19},
	journal = {DYNA},
	author = {Parra-Coronado, Alfonso and García-Navarrete, Oscar Leonardo and Vanegas-Izquierdo, Francy Alejandra and Gamboa-Gamboa, José Alfredo and González-Mora, Andrés Felipe and Ramirez-González, David Andrés},
