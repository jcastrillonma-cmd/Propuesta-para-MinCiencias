@article{hoffstadt_challenges_2020,
	title = {Challenges and {Prospects} of {Biogas} from {Energy} {Cane} as {Supplement} to {Bioethanol} {Production}},
	volume = {10},
	issn = {2073-4395},
	url = {https://www.mdpi.com/2073-4395/10/6/821},
	doi = {10.3390/agronomy10060821},
	abstract = {Innovative breeds of sugar cane yield up to 2.5 times as much organic matter as conventional breeds, resulting in a great potential for biogas production. The use of biogas production as a complementary solution to conventional and second-generation ethanol production in Brazil may increase the energy produced per hectare in the sugarcane sector. Herein, it was demonstrated that through ensiling, energy cane can be conserved for six months; the stored cane can then be fed into a continuous biogas process. This approach is necessary to achieve year-round biogas production at an industrial scale. Batch tests revealed specific biogas potentials between 400 and 600 LN/kgVS for both the ensiled and non-ensiled energy cane, and the specific biogas potential of a continuous biogas process fed with ensiled energy cane was in the same range. Peak biogas losses through ensiling of up to 27\% after six months were observed. Finally, compared with second-generation ethanol production using energy cane, the results indicated that biogas production from energy cane may lead to higher energy yields per hectare, with an average energy yield of up to 162 MWh/ha. Finally, the Farm2CBG concept is introduced, showing an approach for decentralized biogas production.},
	language = {en},
	number = {6},
	urldate = {2026-03-21},
	journal = {Agronomy},
	author = {Hoffstadt, Kevin and Pohen, Gino D. and Dicke, Max D. and Paulsen, Svea and Krafft, Simone and Zang, Joachim W. and Da Fonseca-Zang, Warde A. and Leite, Athaydes and Kuperjans, Isabel},
	month = jun,
	year = {2020},
	pages = {821},
}

